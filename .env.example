# Copy this file to .env and fill in your values. Never commit .env to version control.

# Database: PostgreSQL connection string (or leave unset for local SQLite)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Telegram: Bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Strava OAuth and API
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Redirect URI registered in your Strava API app (e.g. https://your-domain.com/callback)
STRAVA_REDIRECT_URI=
# Verify token for Strava webhook subscription (you choose this value; used in create_strava_webhook.py and app)
STRAVA_VERIFY_TOKEN=
# Full URL where Strava sends webhook events (e.g. https://your-domain.com/webhook). Used by create_strava_webhook.py.
STRAVA_WEBHOOK_URL=

# Google: For Gemini/ADK. Use an API key or Vertex AI.
GOOGLE_API_KEY=
# Set to "true" when using Vertex AI instead of API key
GOOGLE_GENAI_USE_VERTEXAI=

# Optional: Set to "true" to skip ADK/DB init (e.g. for unit tests)
# TESTING=true

# Optional: Server port (default 8080)
# PORT=8080

# Optional: Set to enable debug logging (e.g. parsed DATABASE_URL at startup)
# DEBUG=1
